rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // UID de l'administrateur
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'MMRZK9Dpe4dDTnrU3cTmi32bWb82';
    }

    // ====================================================
    // COLLECTION USERS
    // ====================================================
    match /users/{userId} {

      // Admin : accès total
      allow read, write: if isAdmin();

      // Lecture : seulement soi-même
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // Création : seulement soi-même, sans premium actif
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && (
                         !request.resource.data.keys().hasAny(['premium'])
                         || request.resource.data.premium.active == false
                       );

      // Mise à jour : soi-même, avec validations
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && isValidUpdate(request.resource.data, resource.data);

      // Suppression : interdite côté client
      allow delete: if false;
    }

    // ====================================================
    // COLLECTION PAYMENT_REQUESTS
    // ====================================================
    match /payment_requests/{reqId} {

      // Admin : accès total (lire, valider, rejeter)
      allow read, write: if isAdmin();

      // Client : créer une demande (connecté)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // Client : lire ses propres demandes
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;
    }

    // ====================================================
    // COLLECTION PAYMENTS (historique)
    // ====================================================
    match /payments/{payId} {
      allow read:  if isAdmin()
                   || (request.auth != null
                       && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // ====================================================
    // FONCTIONS DE VALIDATION
    // ====================================================
    function isValidUpdate(incoming, existing) {
      // Soit la mise à jour ne touche pas au champ premium
      // Soit elle respecte les règles premium
      return !incoming.diff(existing).affectedKeys().hasAny(['premium'])
          || isPremiumUpdateValid(incoming, existing);
    }

    function isPremiumUpdateValid(incoming, existing) {
      return !isSelfActivating(incoming, existing)
          && !isChangingExpiry(incoming, existing)
          && !isTooManyDevices(incoming);
      // Note : forceLogout et devices sont autorisés à changer librement
      // (utilisés pour l'éviction automatique d'appareils)
    }

    function isSelfActivating(incoming, existing) {
      // Empêche un utilisateur de s'activer lui-même le premium
      return incoming.premium.get('active', false) == true
          && existing.get('premium', {}).get('active', false) == false;
    }

    function isChangingExpiry(incoming, existing) {
      // Empêche de modifier la date d'expiration
      return incoming.premium.get('expiresAt', null)
          != existing.get('premium', {}).get('expiresAt', null);
    }

    function isTooManyDevices(incoming) {
      // Limite stricte : max 2 appareils simultanés
      return incoming.premium.get('devices', []).size() > 2;
    }
  }
}
